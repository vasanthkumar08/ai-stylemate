# App
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=stylemate-ai

# AI
OPENAI_API_KEY=your_openai_api_key
OPENAI_VISION_MODEL=gpt-5-mini
AI_RECOMMENDATION_TIMEOUT_MS=18000

# Admin security
# Comma-separated emails allowed to access admin surfaces in addition to role=admin.
ADMIN_EMAIL_WHITELIST=admin@example.com

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Monitoring (optional)
MONITORING_WEBHOOK_URL=
CRON_SECRET=your_cron_secret

# Stripe (optional until billing is enabled)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRO_PRICE_ID=your_stripe_price_id
