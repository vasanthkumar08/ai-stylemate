{
  "name": "stylemate-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade AI wardrobe styling SaaS built with Next.js, Supabase, Cloudinary, and TypeScript.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"require('fs').rmSync('.test-build',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node --test .test-build/**/*.test.js",
    "qa": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "latest",
    "@radix-ui/react-slot": "latest",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "cloudinary": "^2.10.0",
    "clsx": "latest",
    "framer-motion": "^12.38.0",
    "lucide-react": "latest",
    "next": "16.2.4",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "recharts": "^3.8.1",
    "tailwind-merge": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "latest",
    "typescript": "latest"
  },
  "overrides": {
    "postcss": "8.5.13"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
