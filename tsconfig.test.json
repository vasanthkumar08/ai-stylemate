{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-build",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "jsx": "react-jsx",
    "incremental": false
  },
  "include": [
    "src/components/wardrobe/**/*.ts",
    "src/lib/cloudinary/**/*.ts",
    "src/features/outfit-recommendation/**/*.ts",
    "src/features/recommendations/engine/**/*.ts",
    "src/features/recommendations/engine/**/*.test.ts"
  ]
}
